<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/header') %>
    <title>Blog</title>
  </head>

  <body>
    <%- include('./partials/nav') %>
    <div class="container mt-4">
      <h1><%= blog.title %></h1>
      <img src="<%= blog.coverImage %>" width="300px" />
      <pre><%= blog.body %></pre>
    </div>


    <div class="container mt-4">
      <img src="<%= blog.createdBy.profileImage %>" width="50px"> 
      <%= blog.createdBy.fullName %>
    </div>

    <%-include('./partials/scripts') %>
  </body>
</html>
